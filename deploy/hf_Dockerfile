# HuggingFace Spaces Dockerfile
# HF Spaces runs on port 7860 and the app must listen on 0.0.0.0:7860

FROM python:3.11-slim

WORKDIR /app

# Install deps
COPY server/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy full project
COPY . .

# HF Spaces requirement: listen on 7860
ENV PORT=7860
ENV HOST=0.0.0.0
ENV WORKERS=1
ENV MAX_STEPS=20
ENV EPISODE_TIMEOUT=300
ENV SUSPICION_THRESHOLD=0.7
ENV LOG_DIR=/tmp/arena_logs

RUN mkdir -p /tmp/arena_logs /tmp/arena_evals

EXPOSE 7860

CMD ["sh", "-c", "uvicorn server.app:app --host $HOST --port $PORT --workers $WORKERS"]
